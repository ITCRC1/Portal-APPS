# ------------------------------------------------------------------------------
# Plantilla de variables de entorno · Portal Interno (The Costa Rica Collection)
#
# Copia este archivo como `.env` y rellena los valores reales.
# El `.env` NUNCA se versiona (está en .gitignore): contiene secretos.
# ------------------------------------------------------------------------------

# Conexión a PostgreSQL (Railway). La usa Prisma.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Secreto para firmar las sesiones (JWT) de Auth.js / NextAuth. OBLIGATORIO.
# Genera uno nuevo con:  npx auth secret     (o)   openssl rand -base64 32
AUTH_SECRET="genera-un-secreto-largo-y-aleatorio"

# ------------------------------------------------------------------------------
# Solo para la siembra inicial (`npx prisma db seed`). No hacen falta en runtime.
# ------------------------------------------------------------------------------

# Contraseña del administrador inicial. OBLIGATORIA la primera vez que se siembra
# (mínimo 12 caracteres). Si el admin ya existe, el seed no la usa ni la cambia.
# No hay contraseña por defecto: sin esta variable, el seed falla a propósito.
SEED_ADMIN_PASSWORD="define-una-clave-fuerte-de-al-menos-12-caracteres"

# Correo del administrador inicial. Opcional; por defecto: it@thecostaricacollection.com
# SEED_ADMIN_EMAIL="it@thecostaricacollection.com"

# ------------------------------------------------------------------------------
# SSO (login único para las demás apps del dominio). Ver docs/SSO.md
# ------------------------------------------------------------------------------

# Secreto compartido con el que se firma el token SSO (JWT HS256). DEBE ser el MISMO
# valor en el portal y en cada app que valide la sesión. Distinto de AUTH_SECRET.
# Genera uno con:  openssl rand -base64 32
SSO_SECRET="genera-un-secreto-largo-y-aleatorio-solo-para-sso"

# Dominio de la cookie SSO. En producción, el dominio raíz con punto inicial para que
# se comparta entre subdominios. Déjalo vacío en local (cookie del propio host).
SSO_COOKIE_DOMAIN=".thecostaricacollection.com"
