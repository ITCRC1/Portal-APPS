# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/tests/authz/.authz-seed.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...pero la plantilla SÍ se versiona (no lleva secretos reales):
!.env.example

# documentos internos: se cargan a la base de datos, nunca al repo
*.docx
*.doc

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma

# RuFlo / Claude Flow — instalación LOCAL de desarrollo, NO versionar.
# Es una herramienta personal; no debe subirse al repo ni desplegarse a Railway.
# Para eliminarla al terminar el proyecto, borra estas carpetas/archivos.
.claude/
.claude-flow/
.swarm/
.mcp.json
ruvector.db
*.db-shm
*.db-wal
