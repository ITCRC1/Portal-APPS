generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model HealthCheck {
  id        String   @id @default(cuid())
  label     String
  createdAt DateTime @default(now())
}

// ---------- Auth.js requerido ----------

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- Dominio: Departamentos y Usuarios ----------

enum Role {
  SUPER_ADMIN
  EXECUTIVE
  DEPARTMENT_MANAGER
  FINANCE_USER
  OPERATIONS_USER
  SALES_USER
  HR_USER
  PROCUREMENT_USER
  MAINTENANCE_USER
  LEGAL_USER
  IT_USER
  READ_ONLY_USER
}

model Department {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerName   String?
  ownerEmail  String?
  icon        String?
  status      String   @default("active")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
  systemLinks SystemLink[]
  documents   Document[]
  tasks       Task[]
  announcements Announcement[]
}

model User {
  id            String    @id @default(cuid())
  fullName      String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String
  role          Role      @default(READ_ONLY_USER)
  avatarUrl     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  accounts Account[]
  sessions Session[]
  documents Document[]
  assignedTasks Task[] @relation("AssignedTasks")
  createdTasks  Task[] @relation("CreatedTasks")
  announcements Announcement[] @relation("PublishedAnnouncements")
  notifications Notification[]
}

model SystemLink {
  id           String      @id @default(cuid())
  name         String
  url          String
  description  String?
  icon         String?
  isActive     Boolean     @default(true)
  order        Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
}

// El archivo se guarda en la propia base (columna bytea) en vez de en el disco del
// contenedor, que se borra en cada deploy. Sirve para documentos corporativos fijos;
// para subida masiva conviene migrar a un volumen de Railway.
model Document {
  id              String      @id @default(cuid())
  name            String
  description     String?
  category        String      @default("Otro")
  fileName        String
  mimeType        String
  size            Int
  content         Bytes
  // public-internal | department | executive | confidential | highly-confidential
  confidentiality String      @default("department")
  status          String      @default("active")
  order           Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  uploadedById String?
  uploadedBy   User?       @relation(fields: [uploadedById], references: [id])
}

// Tarea operativa con alcance por departamento (PRD 13). Las tareas sin departamento
// (departmentId null) son "generales" de la empresa: todos las ven, pero solo los
// roles corporativos (SUPER_ADMIN/EXECUTIVE) pueden crearlas o editarlas.
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("todo")   // todo | in-progress | done
  priority    String    @default("medium")  // low | medium | high
  dueDate     DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  createdById String?
  createdBy   User?    @relation("CreatedTasks", fields: [createdById], references: [id])
}

// Aviso / anuncio interno (PRD 13). Lo publican los roles corporativos; los usuarios
// solo lo leen. Un aviso sin departamento (departmentId null) es general para toda la
// empresa; con departamento, solo lo ve ese departamento (más los roles corporativos).
model Announcement {
  id          String    @id @default(cuid())
  title       String
  body        String
  level       String    @default("info") // info | warning | critical
  status      String    @default("active") // active | archived
  pinned      Boolean   @default(false)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  publishedById String?
  publishedBy   User?    @relation("PublishedAnnouncements", fields: [publishedById], references: [id])
}

// Notificación personal (centro de notificaciones / campana). Una fila por
// destinatario; se genera al asignar una tarea o publicar un aviso de su alcance.
model Notification {
  id        String   @id @default(cuid())
  type      String   // task-assigned | announcement
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

// Bitácora de auditoría: registra quién hizo qué sobre usuarios, departamentos,
// documentos, tareas, avisos y tickets. El actor se guarda como copia (email/rol) para
// que el registro sobreviva aunque el usuario se elimine; por eso no hay relación FK.
model AuditLog {
  id          String   @id @default(cuid())
  action      String   // created | updated | deleted | activated | deactivated | resolved
  entityType  String   // user | department | document | task | announcement | password-request
  entityId    String?
  entityLabel String
  details     String?
  actorId     String?
  actorEmail  String
  actorRole   String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([entityType])
}

// Ticket de solicitud de cambio de contraseña: el usuario pide, el admin lo resuelve
// manualmente desde /admin/users (no hay flujo de auto-reset por correo/token).
model PasswordChangeRequest {
  id         String    @id @default(cuid())
  email      String
  message    String?
  status     String    @default("pending") // pending | resolved
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
}